@model IEnumerable<TradeNest.Models.Category>

@{
    ViewData["Title"] = "Zarządzanie kategoriami";
}

<h1 class="mb-4">Zarządzanie kategoriami</h1>

<a href="@Url.Action("Create", "Category")" class="btn btn-primary-custom my-3">Utwórz kategorię</a>

<style>
    .table-dark-custom {
        background-color: var(--surface-color);
        color: var(--text-primary);
    }

        .table-dark-custom th, .table-dark-custom td {
            border-color: #333;
            color: var(--text-primary);
        }

        .table-dark-custom thead th {
            color: var(--primary-color);
            border-bottom: 2px solid var(--primary-color);
        }

    .btn-primary-custom {
        background-color: var(--primary-color);
        color: #121212;
        border: none;
    }

        .btn-primary-custom:hover {
            background-color: #a361f1;
            color: #121212;
        }
</style>

<div class="table-responsive">
    <table class="table table-dark-custom">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nazwa</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in Model)
            {
                <tr>
                    <td>@category.Id</td>
                    <td>@category.Name</td>
                    <td>
                        <form method="get" action="/Category/Edit/@category.Id" style="display:inline-block">
                            <button class="btn btn-sm btn-info">Edytuj</button>
                        </form>

                        <form method="post" action="/Category/Delete/@category.Id" style="display:inline-block">
                            <button class="btn btn-sm btn-danger">Usuń</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<a href="@Url.Action("Index", "Admin")" class="btn btn-secondary mt-3">Powrót do Panelu</a>