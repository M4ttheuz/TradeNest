@model IEnumerable<TradeNest.Models.Listing>

@{
    ViewData["Title"] = "Zarządzanie Ogłoszeniami";
}

<h1 class="mb-4">Zarządzanie Ogłoszeniami</h1>

<style>
    .table-dark-custom {
        background-color: var(--surface-color);
        color: var(--text-primary);
    }

        .table-dark-custom th, .table-dark-custom td {
            border-color: #333;
            color: var(--text-primary);
        }

        .table-dark-custom thead th {
            color: var(--primary-color);
            border-bottom: 2px solid var(--primary-color);
        }
</style>

<div class="table-responsive">
    <table class="table table-dark-custom mt-4">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tytuł</th>
                <th>Data Utworzenia</th>
                <th>Status</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var listing in Model)
            {
                <tr>
                    <td>@listing.Id</td>
                    <td>@listing.Title</td>
                    <td>@listing.CreatedAt.ToShortDateString()</td>
                    <td>@if (listing.IsVisible)
                    {
                        <span class="badge bg-success">
                            Widoczne
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger">
                            Ukryte
                        </span>
                    }
                    </td>
                    <td>
                        <div class="d-flex gap-2 flex-wrap align-items-center">

                            @if (listing.IsVisible)
                            {
                                <a href="/Listing/Details/@listing.Id"
                                   class="btn btn-secondary-custom">
                                    Skocz Do
                                </a>
                                <a href="/Listing/Edit/@listing.Id"
                                   class="btn btn-primary-custom">
                                    Edytuj
                                </a>

                                <form method="post" action="/Listing/Delete">
                                    <input type="hidden" name="id" value="@listing.Id" />

                                    <button type="submit"
                                            class="btn btn-danger">
                                        @(listing.IsVisible ? "Ukryj" : "Pokaż")
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form method="post" action="/Listing/Delete">
                                    <input type="hidden" name="id" value="@listing.Id" />

                                    <button type="submit"
                                            class="btn btn-danger">
                                        @(listing.IsVisible ? "Ukryj" : "Pokaż")
                                    </button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<a href="@Url.Action("Index", "Admin")" class="btn btn-secondary mt-3">Powrót do panelu</a>