@model IEnumerable<TradeNest.Models.Listing>

@{
    ViewData["Title"] = "Zarządzanie Ogłoszeniami";
}

<h1 class="mb-4">Zarządzanie Ogłoszeniami</h1>

<style>
    .table-dark-custom {
        background-color: var(--surface-color);
        color: var(--text-primary);
    }

        .table-dark-custom th, .table-dark-custom td {
            border-color: #333;
            color: var(--text-primary);
        }

        .table-dark-custom thead th {
            color: var(--primary-color);
            border-bottom: 2px solid var(--primary-color);
        }
</style>

<div class="table-responsive">
    <table class="table table-dark-custom mt-4">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tytuł</th>
                <th>Data Utworzenia</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var listing in Model)
            {
                <tr>
                    <td>@listing.Id</td>
                    <td>@listing.Title</td>
                    <td>@listing.CreatedAt.ToShortDateString()</td>
                    <td>
                        <button class="btn btn-sm btn">Edytuj</button>
                        <button class="btn btn-sm btn-danger">Usuń</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<a href="@Url.Action("Index", "Admin")" class="btn btn-secondary mt-3">Powrót do panelu</a>