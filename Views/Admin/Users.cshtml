@model IEnumerable<TradeNest.Models.User>

@{
    ViewData["Title"] = "Zarządzanie Użytkownikami";
}

<h1 class="mb-4">Zarządzanie Użytkownikami</h1>

<style>
    .table-dark-custom {
        background-color: var(--surface-color);
        color: var(--text-primary);
    }

        .table-dark-custom th, .table-dark-custom td {
            border-color: #333;
            color: var(--text-primary);
        }

        .table-dark-custom thead th {
            color: var(--primary-color);
            border-bottom: 2px solid var(--primary-color);
        }
</style>

<div class="table-responsive">
    <table class="table table-dark-custom mt-4">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nazwa użytkownika</th>
                <th>Rola</th>
                <th>Status</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Id</td>
                    <td>@user.Login</td>
                    <td>@user.Role</td>
                    <td>@if (user.IsActive)
                    {
                        <span class="badge bg-success">
                            Aktywny
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger">
                            Zablokowany
                        </span>
                    }
                    </td>
                    <td>
                        <form asp-action="ToggleUserStatus" asp-controller="Admin" method="post">
                            <input type="hidden" name="userId" value="@user.Id" />

                            <button type="submit"
                                    class="btn btn-sm @(user.IsActive ? "btn-danger" : "btn-success")">
                                @(user.IsActive ? "Zablokuj" : "Odblokuj")
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<a href="@Url.Action("Index", "Admin")" class="btn btn-secondary mt-3">Powrót do panelu</a>