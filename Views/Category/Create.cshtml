@using TradeNest.Models

@{
    ViewData["Title"] = "Tworzenie kategorii";
}

<div class="filter-panel">

    <h1 class="mb-4">Tworzenie kategorii</h1>

    <form method="post">

        <div class="filter-group">
            <label class="filter-label">Nazwa kategorii</label>
            <input type="text" name="categoryName" class="form-control form-control-dark" />
        </div>

        <hr />

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="mb-0">Parametry</h3>

            <button type="button" onclick="addParameter()" class="btn btn-primary-custom">
                Dodaj parametr
            </button>
        </div>

        <div id="parameters">
        </div>

        <button type="submit" class="btn btn-primary-custom w-100 mt-3">
            Utwórz kategorię
        </button>

    </form>

</div>

<script>

    function addParameter()
    {
        const container = document.getElementById("parameters");
        const parameter = document.createElement("div");

        parameter.classList.add("filter-group");

        parameter.innerHTML = `
            <hr />

            <div class="filter-group">
                <label class="filter-label">Nazwa parametru</label>
                <input type="text" name="parameterNames" class="form-control form-control-dark" />
            </div>

            <div class="filter-group">
                <label class="filter-label">Typ</label>

                <select name="parameterTypes" class="form-select form-select-dark">
                    <option value="0">Text</option>
                    <option value="1">Number</option>
                    <option value="2">Boolean</option>
                    <option value="3">Date</option>
                </select>
            </div>

            <div class="filter-group">
                <label class="filter-label d-block">Wymagany</label>

                <input type="hidden" name="parameterRequired" value="false" />
                <input type="checkbox" name="parameterRequired" value="true" />
            </div>

            <button type="button" onclick="removeParameter(this)" class="btn btn-primary-custom">
                Usuń parametr
            </button>
        `;

        container.appendChild(parameter);
    }

    function removeParameter(button)
    {
        button.parentElement.remove();
    }

    addParameter();

</script>