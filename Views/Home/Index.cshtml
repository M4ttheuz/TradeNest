@{
    ViewData["Title"] = "Strona Główna";
    List<TradeNest.Models.Listing> promotedListings = ViewBag.PromotedListings;
}

<div class="row mb-4">
    <div class="col-12">
        <form method="get" asp-controller="Search" asp-action="Index">
            <div class="input-group">
                <input name="phrase"
                       class="form-control form-control-dark"
                       type="search"
                       placeholder="Czego szukasz?" />
                <button class="btn btn-primary-custom" type="submit">
                    <i class="bi bi-search"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="hero-categories">
            <a asp-controller="Search"
               asp-action="SearchByCategory"
               asp-route-name="Motoryzacja"
               class="category-item">
                <div class="category-icon"><i class="bi bi-car-front"></i></div>
                <span>Motoryzacja</span>
            </a>

            <a asp-controller="Search"
               asp-action="SearchByCategory"
               asp-route-name="Elektronika"
               class="category-item">
                <div class="category-icon"><i class="bi bi-laptop"></i></div>
                <span>Elektronika</span>
            </a>

            <a asp-controller="Search"
               asp-action="SearchByCategory"
               asp-route-name="Moda"
               class="category-item">
                <div class="category-icon"><i class="bi bi-bag"></i></div>
                <span>Moda</span>
            </a>

            <a asp-controller="Search"
               asp-action="SearchByCategory"
               asp-route-name="Nieruchomości"
               class="category-item">
                <div class="category-icon"><i class="bi bi-house"></i></div>
                <span>Nieruchomości</span>
            </a>

            <a asp-controller="Search"
               asp-action="SearchByCategory"
               asp-route-name="Usługi"
               class="category-item">
                <div class="category-icon"><i class="bi bi-tools"></i></div>
                <span>Usługi</span>
            </a>

            <a asp-controller="Search"
               asp-action="SearchByCategory"
               asp-route-name="Hobby"
               class="category-item">
                <div class="category-icon"><i class="bi bi-controller"></i></div>
                <span>Hobby</span>
            </a>
        </div>
    </div>
</div>

@if (promotedListings != null && promotedListings.Count > 0)
{
    <div class="row mb-5">
        <div class="col-12">
            <h4 class="section-title">Promowane ogłoszenia</h4>
            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
                @foreach (var listing in promotedListings)
                {
                    var prices = listing.Prices.OrderByDescending(x => x.SetAt).ToList();
                    double? price = prices.ElementAtOrDefault(0)?.Price;
                    double? prevPrice = prices.ElementAtOrDefault(1)?.Price;

                    var reviewsCount = listing.Owner.ReviewsCount;
                    var averageRating = Math.Round((listing.Owner.AverageRating ?? 0) * 2, MidpointRounding.AwayFromZero) / 2;

                    <div class="col">
                        <a asp-controller="Listing"
                           asp-action="Details"
                           asp-route-id="@listing.Id"
                           class="text-decoration-none text-reset">
                            <div class="listing-card promoted-listing-card">
                                <div class="listing-img-wrapper">
                                    @{
                                        var mainImage = listing.Images.FirstOrDefault(x => x.IsMain);
                                    }
                                    @if (mainImage != null)
                                    {
                                        <img src="@mainImage.ImagePath" class="listing-img" alt="@listing.Title" />
                                    }
                                    else
                                    {
                                        <div class="listing-no-image-wrapper">
                                            <i class="bi bi-image text-muted fs-1"></i>
                                        </div>
                                    }
                                    <span class="promoted-badge">Promowane</span>
                                    <form asp-controller="Watchlist" asp-action="Toggle" method="post">
                                        <input type="hidden" name="listingId" value="@listing.Id" />
                                        <button type="submit" class="watchlist-btn">
                                            <i class="bi bi-heart"></i>
                                        </button>
                                    </form>
                                </div>
                                <div class="card-body">
                                    <h5 class="card-title">@listing.Title</h5>
                                    <div class="rating-stars">
                                        @if (reviewsCount == 0)
                                        {
                                            <span class="text-muted fst-italic">Brak opinii</span>
                                        }
                                        else
                                        {
                                            var fullStars = (int)Math.Floor(averageRating);
                                            var hasHalfStar = averageRating - fullStars >= 0.5;

                                            @for (int i = 0; i < fullStars; i++)
                                            {
                                                <i class="bi bi-star-fill"></i>
                                            }

                                            @if (hasHalfStar)
                                            {
                                                <i class="bi bi-star-half"></i>
                                            }

                                            @for (int i = fullStars + (hasHalfStar ? 1 : 0); i < 5; i++)
                                            {
                                                <i class="bi bi-star"></i>
                                            }

                                            <span class="text-muted ms-1">(@reviewsCount)</span>
                                        }
                                    </div>
                                    <div class="card-price-row">
                                        <p class="card-price">@(price?.ToString("0.##")) zł</p>
                                        @if (prevPrice.HasValue && price.HasValue)
                                        {
                                            if (price < prevPrice)
                                            {
                                                <div class="price-history" title="Cena spada">
                                                    <i class="bi bi-graph-down-arrow"></i>
                                                </div>
                                            }
                                            else if (price > prevPrice)
                                            {
                                                <div class="price-history" style="color:#ff5252" title="Cena rośnie">
                                                    <i class="bi bi-graph-up-arrow"></i>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="price-history text-muted" title="Cena bez zmian">
                                                    <i class="bi bi-dash"></i>
                                                </div>
                                            }
                                        }
                                    </div>
                                    <div class="card-footer-info">
                                        <span><i class="bi bi-tag me-1"></i>@listing.Category.Name</span>
                                        @if (listing.CreatedAt.Date == DateTime.Now.Date)
                                        {
                                            <span>Dzisiaj o @listing.CreatedAt.ToString("HH:mm")</span>
                                        }
                                        else if (listing.CreatedAt.Date == DateTime.Now.Date.AddDays(-1))
                                        {
                                            <span>Wczoraj o @listing.CreatedAt.ToString("HH:mm")</span>
                                        }
                                        else
                                        {
                                            <span>@listing.CreatedAt.ToString("dd.MM.yyyy")</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
}


<div class="row">
    <div class="col-12">
        <h4 class="section-title">Najnowsze ogłoszenia</h4>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">

            @{
                var savedListingIds = ViewBag.SavedListingIds as List<int> ?? new List<int>();
            }

            @foreach (TradeNest.Models.Listing listing in Model)
            {
                bool isSaved = savedListingIds.Contains(listing.Id);
                var isPromoted = listing.IsPromoted && listing.PromotionEndDate > DateTime.Now;

                var prices = listing.Prices.OrderByDescending(x => x.SetAt).ToList();
                double? price = prices.ElementAtOrDefault(0)?.Price;
                double? prevPrice = prices.ElementAtOrDefault(1)?.Price;

                var reviewsCount = listing.Owner.ReviewsCount;
                var averageRating = Math.Round((listing.Owner.AverageRating ?? 0) * 2, MidpointRounding.AwayFromZero) / 2;

                <div class="col">
                    <a asp-controller="Listing"
                       asp-action="Details"
                       asp-route-id="@listing.Id"
                       class="text-decoration-none text-reset">
                        <div class="listing-card @(isPromoted ? "promoted-listing-card" : "")">
                            <div class="listing-img-wrapper">
                                @{
                                    var mainImage = listing.Images.FirstOrDefault(x => x.IsMain);
                                }
                                @if (mainImage != null)
                                {
                                    <img src="@mainImage.ImagePath" class="listing-img" alt="@listing.Title" />
                                }
                                else
                                {
                                    <div class="listing-no-image-wrapper">
                                        <i class="bi bi-image text-muted fs-1"></i>
                                    </div>
                                }
                                @if (isPromoted)
                                {
                                    <span class="promoted-badge">Promowane</span>
                                }
                                <form asp-controller="Watchlist" asp-action="Toggle" method="post">
                                    <input type="hidden" name="listingId" value="@listing.Id" />
                                    <button type="submit" class="watchlist-btn">
                                        @if (isSaved)
                                        {
                                            <i class="bi bi-heart-fill"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-heart"></i>
                                        }
                                    </button>
                                </form>
                            </div>
                            <div class="card-body">
                                <h5 class="card-title">@listing.Title</h5>
                                <div class="rating-stars">
                                    @if (reviewsCount == 0)
                                    {
                                        <span class="text-muted fst-italic">Brak opinii</span>
                                    }
                                    else
                                    {
                                        var fullStars = (int)Math.Floor(averageRating);
                                        var hasHalfStar = averageRating - fullStars >= 0.5;

                                        @for (int i = 0; i < fullStars; i++)
                                        {
                                            <i class="bi bi-star-fill"></i>
                                        }

                                        @if (hasHalfStar)
                                        {
                                            <i class="bi bi-star-half"></i>
                                        }

                                        @for (int i = fullStars + (hasHalfStar ? 1 : 0); i < 5; i++)
                                        {
                                            <i class="bi bi-star"></i>
                                        }

                                        <span class="text-muted ms-1">(@reviewsCount)</span>
                                    }
                                </div>
                                <div class="card-price-row">
                                    <p class="card-price">@(price?.ToString("0.##")) zł</p>
                                    @if (prevPrice.HasValue && price.HasValue)
                                    {
                                        if (price < prevPrice)
                                        {
                                            <div class="price-history" title="Cena spada">
                                                <i class="bi bi-graph-down-arrow"></i>
                                            </div>
                                        }
                                        else if (price > prevPrice)
                                        {
                                            <div class="price-history" style="color:#ff5252" title="Cena rośnie">
                                                <i class="bi bi-graph-up-arrow"></i>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="price-history text-muted" title="Cena bez zmian">
                                                <i class="bi bi-dash"></i>
                                            </div>
                                        }
                                    }
                                </div>
                                <div class="card-footer-info">
                                    <span><i class="bi bi-tag me-1"></i>@listing.Category.Name</span>
                                    @if (listing.CreatedAt.Date == DateTime.Now.Date)
                                    {
                                        <span>Dzisiaj o @listing.CreatedAt.ToString("HH:mm")</span>
                                    }
                                    else if (listing.CreatedAt.Date == DateTime.Now.Date.AddDays(-1))
                                    {
                                        <span>Wczoraj o @listing.CreatedAt.ToString("HH:mm")</span>
                                    }
                                    else
                                    {
                                        <span>@listing.CreatedAt.ToString("dd.MM.yyyy")</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
        <div class="text-center mt-4 mb-5">
            <button class="btn btn-secondary-custom px-4 rounded-pill">Załaduj więcej</button>
        </div>
    </div>
</div>

@* heart *@
<script>
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.watchlist-btn').forEach(btn => {
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                this.closest('form').submit();
            });
        });
    });
</script>