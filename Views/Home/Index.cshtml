                    </div>
                    <div class="card-body">
                        <h5 class="card-title">Skórzana Kurtka Vintage Rozm. L</h5>
                        <div class="rating-stars">
                             <span class="text-muted fst-italic">Brak opinii</span>
                        </div>
                        <div class="card-price-row">
                            <p class="card-price">420 zł</p>
                        </div>
                        <div class="card-footer-info">
                            <span><i class="bi bi-geo-alt me-1"></i>Poznań</span>
                            <span>2 dni temu</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
   
    <div class="col-lg-9">
        <h4 class="section-title">Najnowsze ogłoszenia</h4>

        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">

            @foreach (TradeNest.Models.Listing listing in Model)
            {
                double? price = listing.Prices
                .OrderByDescending(x => x.SetAt)
                .FirstOrDefault()?.Price;

                <div class="col">

                    <a asp-controller="Listing"
                       asp-action="Details"
                       asp-route-id="@listing.Id"
                       class="text-decoration-none text-reset">

                        <div class="listing-card">

                            <div class="listing-img-wrapper">

                                <div style="position:absolute;top:0;left:0;width:100%;height:100%;background-color:#2a2a2a;display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-image text-muted fs-1"></i>
                                </div>

                                @* <button class="watchlist-btn">
                                    <i class="bi bi-heart"></i>
                                </button> *@
                                <form asp-controller="Watchlist"
                                      asp-action="Toggle"
                                      method="post">

                                    <input type="hidden"
                                           name="listingId"
                                           value="@listing.Id" />

                                    <button type="submit" class="watchlist-btn">
                                        <i class="bi bi-heart"></i>
                                    </button>

                                </form>

                            </div>

                            <div class="card-body">

                                <h5 class="card-title">
                                    @listing.Title
                                </h5>

                                <div class="rating-stars">
                                    <span class="text-muted fst-italic">
                                        Brak opinii
                                    </span>
                                </div>

                                <div class="card-price-row">

                                    <p class="card-price">
                                        @(price?.ToString("0.##")) zł
                                    </p>

                                </div>

                                <div class="card-footer-info">

                                    <span>
                                        <i class="bi bi-tag me-1"></i>
                                        @listing.Category.Name
                                    </span>

                                    <span>
                                        @listing.CreatedAt.ToString("dd.MM.yyyy")
                                    </span>

                                </div>

                            </div>

                        </div>

                    </a>

                </div>
            }

        </div>
    </div>
        
        <div class="text-center mt-4 mb-5">
            <button class="btn btn-secondary-custom px-4 rounded-pill">Załaduj więcej</button>
        </div>
    </div>
</div>

@* heart *@
<script>
    document.addEventListener('DOMContentLoaded', function () {

        document.querySelectorAll('.watchlist-btn').forEach(btn => {

            btn.addEventListener('click', function (e) {

                e.preventDefault();
                e.stopPropagation();

                this.closest('form').submit();
            });

        });

    });
</script>