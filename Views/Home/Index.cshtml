                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <span class="text-muted ms-1">(12)</span>
                        </div>
                        <div class="card-price-row">
                            <p class="card-price">135 000 zł</p>
                            <div class="price-history text-muted" title="Cena bez zmian">
                                <i class="bi bi-dash"></i>
                            </div>
                        </div>
                        <div class="card-footer-info">
                            <span><i class="bi bi-geo-alt me-1"></i>Kraków</span>
