<script>
    function changeMainImage(imagePath, thumbnailElement) {
        const mainImg = document.getElementById('currentMainImage');
        if (mainImg) {
            mainImg.src = imagePath;
        }

        document.querySelectorAll('.gallery-thumbnail-wrapper img').forEach(img => {
            img.classList.remove('border-primary');
        });

        thumbnailElement.classList.add('border-primary');
    }
</script>