@model TradeNest.Models.Listing

<h1>Edycja ogłoszenia</h1>

<form method="post">

    <input type="hidden" name="id" value="@Model.Id" />

    <div>
        <label>Tytuł</label>
        <input type="text" name="title" value="@Model.Title" />
    </div>

    <div>
        <label>Opis</label>

        <textarea name="description">@Model.Description</textarea>
    </div>

    <div>
        <label>Kategoria</label>

        <input type="text" value="@Model.Category.Name" disabled />
    </div>

    <div>
        <label>Cena</label>

        <input type="number"
               step="0.01"
               name="price"
               value="@(Model.Prices.OrderByDescending(x => x.SetAt).FirstOrDefault()?.Price)" />
    </div>

    <hr />

    @foreach (TradeNest.Models.ListingParameterValue parameter in Model.ParameterValues)
    {
        <div>

            <label>
                @parameter.CategoryParameter.Name
            </label>

            <input type="hidden"
                   name="parameterValueIds"
                   value="@parameter.Id" />

            @if (parameter.CategoryParameter.Type == TradeNest.Models.ParameterType.Text)
            {
                <input type="text"
                       name="parameterValues"
                       value="@parameter.Value" />
            }

            @if (parameter.CategoryParameter.Type == TradeNest.Models.ParameterType.Number)
            {
                <input type="number"
                       name="parameterValues"
                       value="@parameter.Value" />
            }

            @if (parameter.CategoryParameter.Type == TradeNest.Models.ParameterType.Date)
            {
                <input type="date"
                       name="parameterValues"
                       value="@parameter.Value" />
            }

            @if (parameter.CategoryParameter.Type == TradeNest.Models.ParameterType.Boolean)
            {
                <input type="hidden"
                       name="parameterValues"
                       value="false" />

                @if (parameter.Value == "true")
                {
                    <input type="checkbox"
                           name="parameterValues"
                           value="true"
                           checked />
                }
                else
                {
                    <input type="checkbox"
                           name="parameterValues"
                           value="true" />
                }
            }

        </div>
    }

    <button type="submit">
        Zapisz
    </button>

</form>