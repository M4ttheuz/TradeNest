@model List<Listing>

@{
	if (string.IsNullOrEmpty(ViewBag.Phrase))
    {
        ViewData["Title"] = "Wyszukiwanie";
    }
    else
    {
        ViewData["Title"] = ViewBag.Phrase;
    }

    int? selectedCategoryId = ViewBag.SelectedCategoryId;
    List<Category> categories = ViewBag.Categories;
    Dictionary<string, string> filters = ViewBag.Filters ?? new Dictionary<string, string>();

    Category? selectedCategory = selectedCategoryId.HasValue
        ? categories.FirstOrDefault(x => x.Id == selectedCategoryId)
        : null;
}

<div class="row">

    <div class="col-lg-3">

        <form method="get">

            <div class="filter-panel">

                <h5>Filtry</h5>

                <div class="filter-group">
                    <label class="filter-label">Fraza</label>
                    <input type="text"
                           name="phrase"
                           value="@ViewBag.Phrase"
                           class="form-control form-control-dark" />
                </div>

                <div class="filter-group">
                    <label class="filter-label">Kategoria</label>
                    <select name="categoryId"
                            onchange="this.form.submit()"
                            class="form-select form-select-dark">
                        <option value="">Wszystkie</option>
                        @foreach (var category in categories)
                        {
                            <option value="@category.Id"
                                    selected="@(category.Id == selectedCategoryId)">
                                @category.Name
                            </option>
                        }
                    </select>
                </div>

                <div class="filter-group">
                    <label class="filter-label">Cena</label>
                    <div class="d-flex gap-2">
                        <input type="number"
                               step="0.01"
                               name="minPrice"
                               value="@ViewBag.MinPrice"
                               placeholder="Od"
                               class="form-control form-control-dark" />
                        <input type="number"
                               step="0.01"
                               name="maxPrice"
                               value="@ViewBag.MaxPrice"
                               placeholder="Do"
                               class="form-control form-control-dark" />
                    </div>
                </div>

                @if (selectedCategory != null)
                {
                    foreach (var parameter in selectedCategory.Parameters)
                    {
                        <div class="filter-group">
                            <label class="filter-label">@parameter.Name</label>

                            @if (parameter.Type == ParameterType.Text)
                            {
                                <input type="text"
                                       name="filters[@parameter.Id]"
                                       value="@(filters.GetValueOrDefault(parameter.Id.ToString()))"
                                       class="form-control form-control-dark" />
                            }
                            @if (parameter.Type == ParameterType.Number)
                            {
                                <div class="d-flex gap-2">
                                    <input type="number"
                                           name="filters[@(parameter.Id + "_min")]"
                                           value="@(filters.GetValueOrDefault(parameter.Id + "_min"))"
                                           placeholder="Od"
                                           class="form-control form-control-dark" />
                                    <input type="number"
                                           name="filters[@(parameter.Id + "_max")]"
                                           value="@(filters.GetValueOrDefault(parameter.Id + "_max"))"
                                           placeholder="Do"
                                           class="form-control form-control-dark" />
                                </div>
                            }
                            @if (parameter.Type == ParameterType.Boolean)
                            {
                                <select name="filters[@parameter.Id]"
                                        class="form-select form-select-dark">
                                    <option value="">Dowolne</option>
                                    <option value="true" selected="@(filters.GetValueOrDefault(parameter.Id.ToString()) == "true")">Tak</option>
                                    <option value="false" selected="@(filters.GetValueOrDefault(parameter.Id.ToString()) == "false")">Nie</option>
                                </select>
                            }
                            @if (parameter.Type == ParameterType.Date)
                            {
                                <input type="date"
                                       name="filters[@parameter.Id]"
                                       value="@(filters.GetValueOrDefault(parameter.Id.ToString()))"
                                       class="form-control form-control-dark" />
                            }

                        </div>
                    }
                }

                <button class="btn btn-primary-custom w-100 mt-2">
                    Zastosuj filtry
                </button>

            </div>

        </form>

    </div>

    <div class="col-lg-9">

        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">

            @foreach (var listing in Model)
            {
                var isPromoted = listing.IsPromoted && listing.PromotionEndDate > DateTime.Now;

                var prices = listing.Prices.OrderByDescending(x => x.SetAt).ToList();
                double? price = prices.ElementAtOrDefault(0)?.Price;
                double? prevPrice = prices.ElementAtOrDefault(1)?.Price;

                var reviewsCount = listing.Owner.ReviewsCount;
                var averageRating = Math.Round((listing.Owner.AverageRating ?? 0) * 2, MidpointRounding.AwayFromZero) / 2;

                <div class="col">
                    <a asp-controller="Listing"
                       asp-action="Details"
                       asp-route-id="@listing.Id"
                       class="text-decoration-none text-reset">
                        <div class="listing-card @(isPromoted ? "promoted-listing-card" : "")">
                            <div class="listing-img-wrapper">
                                @{
                                    var mainImage = listing.Images.FirstOrDefault(x => x.IsMain);
                                }
                                @if (mainImage != null)
                                {
                                    <img src="@mainImage.ImagePath" class="listing-img" alt="@listing.Title" />
                                }
                                else
                                {
                                    <div class="listing-no-image-wrapper">
                                        <i class="bi bi-image text-muted fs-1"></i>
                                    </div>
                                }
                                @if (isPromoted)
                                {
                                    <span class="promoted-badge">Promowane</span>
                                }
                                <form asp-controller="Watchlist" asp-action="Toggle" method="post">
                                    <input type="hidden" name="listingId" value="@listing.Id" />
                                    <button type="submit" class="watchlist-btn">
                                        <i class="bi bi-heart"></i>
                                    </button>
                                </form>
                            </div>
                            <div class="card-body">
                                <h5 class="card-title">@listing.Title</h5>
                                <div class="rating-stars">
                                    @if (reviewsCount == 0)
                                    {
                                        <span class="text-muted fst-italic">Brak opinii</span>
                                    }
                                    else
                                    {
                                        var fullStars = (int)Math.Floor(averageRating);
                                        var hasHalfStar = averageRating - fullStars >= 0.5;

                                        @for (int i = 0; i < fullStars; i++)
                                        {
                                            <i class="bi bi-star-fill"></i>
                                        }

                                        @if (hasHalfStar)
                                        {
                                            <i class="bi bi-star-half"></i>
                                        }

                                        @for (int i = fullStars + (hasHalfStar ? 1 : 0); i < 5; i++)
                                        {
                                            <i class="bi bi-star"></i>
                                        }

                                        <span class="text-muted ms-1">(@reviewsCount)</span>
                                    }
                                </div>
                                <div class="card-price-row">
                                    <p class="card-price">@(price?.ToString("0.##")) zł</p>
                                    @if (prevPrice.HasValue && price.HasValue)
                                    {
                                        if (price < prevPrice)
                                        {
                                            <div class="price-history" title="Cena spada">
                                                <i class="bi bi-graph-down-arrow"></i>
                                            </div>
                                        }
                                        else if (price > prevPrice)
                                        {
                                            <div class="price-history" style="color:#ff5252" title="Cena rośnie">
                                                <i class="bi bi-graph-up-arrow"></i>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="price-history text-muted" title="Cena bez zmian">
                                                <i class="bi bi-dash"></i>
                                            </div>
                                        }
                                    }
                                </div>
                                <div class="card-footer-info">
                                    <span><i class="bi bi-tag me-1"></i>@listing.Category.Name</span>
                                    @if (listing.CreatedAt.Date == DateTime.Now.Date)
                                    {
                                        <span>Dzisiaj o @listing.CreatedAt.ToString("HH:mm")</span>
                                    }
                                    else if (listing.CreatedAt.Date == DateTime.Now.Date.AddDays(-1))
                                    {
                                        <span>Wczoraj o @listing.CreatedAt.ToString("HH:mm")</span>
                                    }
                                    else
                                    {
                                        <span>@listing.CreatedAt.ToString("dd.MM.yyyy")</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }

        </div>

    </div>

</div>