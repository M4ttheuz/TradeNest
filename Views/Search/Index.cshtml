@model List<Listing>

@{
    int? selectedCategoryId = ViewBag.SelectedCategoryId;
    List<Category> categories = ViewBag.Categories;

    Category? selectedCategory = selectedCategoryId.HasValue
        ? categories.FirstOrDefault(x => x.Id == selectedCategoryId)
        : null;
}

<div class="row">

    <div class="col-lg-3">

        <form method="get">

            <div class="filter-panel">

                <h5>Filtry</h5>

                <div class="filter-group">
                    <label class="filter-label">Fraza</label>
                    <input type="text"
                           name="phrase"
                           value="@ViewBag.Phrase"
                           class="form-control form-control-dark" />
                </div>

                <div class="filter-group">
                    <label class="filter-label">Kategoria</label>
                    <select name="categoryId"
                            onchange="this.form.submit()"
                            class="form-select form-select-dark">
                        <option value="">Wszystkie</option>
                        @foreach (var category in categories)
                        {
                            <option value="@category.Id"
                                    selected="@(category.Id == selectedCategoryId)">
                                @category.Name
                            </option>
                        }
                    </select>
                </div>

                <div class="filter-group">
                    <label class="filter-label">Cena</label>
                    <div class="d-flex gap-2">
                        <input type="number"
                               step="0.01"
                               name="minPrice"
                               value="@ViewBag.MinPrice"
                               placeholder="Od"
                               class="form-control form-control-dark" />
                        <input type="number"
                               step="0.01"
                               name="maxPrice"
                               value="@ViewBag.MaxPrice"
                               placeholder="Do"
                               class="form-control form-control-dark" />
                    </div>
                </div>

                @if (selectedCategory != null)
                {
                    foreach (var parameter in selectedCategory.Parameters)
                    {
                        <div class="filter-group">
                            <label class="filter-label">@parameter.Name</label>

                            @if (parameter.Type == ParameterType.Text)
                            {
                                <input type="text"
                                       name="filters[@parameter.Id]"
                                       class="form-control form-control-dark" />
                            }
                            @if (parameter.Type == ParameterType.Number)
                            {
                                <div class="d-flex gap-2">
                                    <input type="number"
                                           name="filters[@(parameter.Id + "_min")]"
                                           placeholder="Od"
                                           class="form-control form-control-dark" />
                                    <input type="number"
                                           name="filters[@(parameter.Id + "_max")]"
                                           placeholder="Do"
                                           class="form-control form-control-dark" />
                                </div>
                            }
                            @if (parameter.Type == ParameterType.Boolean)
                            {
                                <select name="filters[@parameter.Id]"
                                        class="form-select form-select-dark">
                                    <option value="">Dowolne</option>
                                    <option value="true">Tak</option>
                                    <option value="false">Nie</option>
                                </select>
                            }
                            @if (parameter.Type == ParameterType.Date)
                            {
                                <input type="date"
                                       name="filters[@parameter.Id]"
                                       class="form-control form-control-dark" />
                            }
                        </div>
                    }
                }

                <button class="btn btn-primary-custom w-100 mt-2">
                    Zastosuj filtry
                </button>

            </div>

        </form>

    </div>

    <div class="col-lg-9">

        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">

            @foreach (var listing in Model)
            {
                double? price = listing.Prices
                .OrderByDescending(x => x.SetAt)
                .FirstOrDefault()?.Price;

                <div class="col">
                    <a asp-controller="Listing"
                       asp-action="Details"
                       asp-route-id="@listing.Id"
                       class="text-decoration-none text-reset">

                        <div class="listing-card">
                            <div class="listing-img-wrapper">
                                @{
                                    var mainImage = listing.Images.FirstOrDefault(x => x.IsMain);
                                }
                                @if (mainImage != null)
                                {
                                    <img src="@mainImage.ImagePath" class="w-100 h-100" />
                                }
                                else
                                {
                                    <div style="position:absolute;top:0;left:0;width:100%;height:100%;background-color:#2a2a2a;display:flex;align-items:center;justify-content:center;">
                                        <i class="bi bi-image text-muted fs-1"></i>
                                    </div>
                                }
                                <button class="watchlist-btn">
                                    <i class="bi bi-heart"></i>
                                </button>
                            </div>

                            <div class="card-body">
                                <h5 class="card-title">@listing.Title</h5>
                                <div class="rating-stars">
                                    <span class="text-muted fst-italic">Brak opinii</span>
                                </div>
                                <div class="card-price-row">
                                    <p class="card-price">@(price?.ToString("0.##")) zł</p>
                                </div>
                                <div class="card-footer-info">
                                    <span>
                                        <i class="bi bi-tag me-1"></i>@listing.Category.Name
                                    </span>
                                    <span>@listing.CreatedAt.ToString("dd.MM.yyyy")</span>
                                </div>
                            </div>
                        </div>

                    </a>
                </div>
            }

        </div>

    </div>

</div>