@model TradeNest.ViewModels.UserRatingsViewModel

<div class="container mt-5">
    <div class="row">

        <div class="col-md-4 mb-4">
            <div class="card p-4 shadow-sm bg-dark text-light border-0" style="border-radius: 12px;">
                <div class="text-center mb-3">
                    <div class="bg-secondary rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 70px; height: 70px;">
                        <i class="bi bi-person-fill text-white fs-2"></i>
                    </div>
                    <h4 class="mb-0">@Model.User.Login</h4>
                    <p class="text-secondary small">Użytkownik TradeNest</p>
                </div>

                <hr class="border-secondary" />

                <div class="main-rating-box text-center py-3 mb-4 bg-black bg-opacity-25 rounded">
                    <label class="text-secondary d-block small uppercase fw-bold mb-1">Główna ocena</label>
                    @if (Model.User.AverageRating.HasValue)
                    {
                        <h2 class="text-warning fw-bold mb-0">@Model.User.AverageRating.Value.ToString("F2")<span class="fs-6 text-secondary"> / 5</span></h2>
                        <div class="text-warning small mt-1">
                            @{
                                int mainStars = (int)Math.Round(Model.User.AverageRating.Value);
                                for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= mainStars)
                                    {
                                        <i class="bi bi-star-fill"></i>
                                    }
                                    else
                                    {

                                        <i class="bi bi-star"></i>
                                    }
                                }
                            }
                        </div>
                    }
                    else
                    {
                        <h5 class="text-muted mb-1">— / 5</h5>
                        @if(Model.User.ReviewsCount == 0)
                        {
                            <p class="text-warning x-small px-2 mb-0" style="font-size: 0.8rem;">
                                Brak Opinii
                            </p>
                        }
                        
                    }
                </div>

                <div class="filter-panel">
                    <h6 class="text-light mb-3 fw-bold">Szczegóły ocen</h6>

                    <div class="stats-row d-flex justify-content-between align-items-center mb-3">
                        <span class="text-secondary small"><i class="bi bi-card-text me-2"></i>Zgodność z opisem</span>
                        <span class="badge bg-secondary text-light p-2">
                            @(Model.User.ReceivedReviews.Any() ? Model.User.AverageDescriptionRating.ToString("F1") : "—") / 5
                        </span>
                    </div>

                    <div class="stats-row d-flex justify-content-between align-items-center mb-3">
                        <span class="text-secondary small"><i class="bi bi-clock me-2"></i>Czas odpowiedzi</span>
                        <span class="badge bg-secondary text-light p-2">
                            @(Model.User.ReceivedReviews.Any() ? Model.User.AverageResponseTimeRating.ToString("F1") : "—") / 5
                        </span>
                    </div>

                    <div class="stats-row d-flex justify-content-between align-items-center">
                        <span class="text-secondary small"><i class="bi bi-emoji-smile me-2"></i>Uprzejmość</span>
                        <span class="badge bg-secondary text-light p-2">
                            @(Model.User.ReceivedReviews.Any() ? Model.User.AveragePolitenessRating.ToString("F1") : "—") / 5
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card p-4 shadow-sm border-0" style="border-radius: 12px;">

                <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                    <h4 class="mb-0 text-dark fw-bold">
                        Opinie <span class="text-muted fs-5">(@Model.User.ReviewsCount)</span>
                    </h4>

                    <div class="d-flex align-items-center">
                        <label for="sortSelect" class="me-2 text-secondary small text-nowrap">Sortuj według:</label>
                        <select id="sortSelect" class="form-select form-select-sm" style="width: 180px;">
                            <option value="Najnowsze" selected="@(Model.CurrentSort == "Najnowsze")">Najnowsze</option>
                            <option value="Najwyższe oceny" selected="@(Model.CurrentSort == "Najwyższe oceny")">Najwyższe oceny</option>
                            <option value="Najniższe oceny" selected="@(Model.CurrentSort == "Najniższe oceny")">Najniższe oceny</option>
                        </select>
                    </div>
                </div>

                @if (!Model.Reviews.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-chat-left-heart text-muted display-4"></i>
                        <p class="text-secondary mt-3">Ten użytkownik nie otrzymał jeszcze żadnych opinii.</p>
                    </div>
                }
                else
                {
                    @foreach (var review in Model.Reviews)
                    {
                        <div class="review-item mb-4 p-3 bg-light rounded shadow-sm border-start border-primary-custom border-4">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <span class="fw-bold text-dark">@review.Author.Login</span>
                                    <span class="text-muted mx-2">•</span>
                                    <span class="text-secondary small">@review.CreatedAt.ToString("dd.MM.yyyy")</span>
                                </div>

                                <div class="rating-stars" data-bs-toggle="tooltip" data-bs-placement="top"
                                     title="Opis: @review.DescriptionRating/5 | Czas: @review.ResponseTimeRating/5 | Uprzejmość: @review.PolitenessRating/5">
                                    @{
                                        int reviewStars = (int)Math.Round(review.AverageReviewRating);
                                        for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= reviewStars)
                                            {
                                                <i class="bi bi-star-fill text-warning"></i>
                                            }
                                            else
                                            {

                                                <i class="bi bi-star text-muted"></i>
                                            }
                                        }
                                    }
                                    <span class="text-dark fw-bold small ms-1">@review.AverageReviewRating.ToString("F1")</span>
                                </div>
                            </div>

                            @if (review.Listing != null)
                            {
                                <div class="mb-2">
                                    <small class="text-muted">
                                        <i class="bi bi-tag-fill me-1"></i> Dotyczy ogłoszenia:
                                        <a href="/Listing/Details/@review.ListingId" class="text-decoration-none text-primary fw-medium">@review.Listing.Title</a>
                                    </small>
                                </div>
                            }

                            <p class="text-dark mb-0 mt-2" style="white-space: pre-line;">
                                @review.Comment
                            </p>
                        </div>
                    }
                }
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('sortSelect').addEventListener('change', function () {
            const sortBy = this.value;
            const url = new URL(window.location.href);


            url.searchParams.set('sortBy', sortBy);
            window.location.href = url.toString();
        });


        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        });
    </script>
}