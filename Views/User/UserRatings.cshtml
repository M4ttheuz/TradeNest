@{
    ViewData["Title"] = "Oceny użytkownika - Jan Kowalski";
}

<div class="row mt-4">
    <!-- Lewa kolumna: Podsumowanie profilu -->
    <div class="col-lg-4">
        <div class="filter-panel mb-4 text-center p-4">
            <div class="user-avatar-large mb-3 mx-auto">
                <i class="bi bi-person-circle display-1 text-secondary"></i>
            </div>
            <h3 class="fw-bold text-light">Jan Kowalski</h3>
            <p class="text-secondary">Na TradeNest od paź 2023</p>

            <div class="d-flex justify-content-center gap-2 mb-3">
                <span class="badge bg-success"><i class="bi bi-shield-check me-1"></i>Zweryfikowany</span>
                <span class="badge bg-primary"><i class="bi bi-award me-1"></i>Polecany</span>
            </div>

            <hr class="border-secondary">

            <div class="rating-summary-box py-2">
                <h1 class="display-4 fw-bold text-primary-custom mb-0">4.8</h1>
                <div class="rating-stars fs-4 mb-2">
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-half"></i>
                </div>
                <p class="text-secondary small">na podstawie 124 ocen</p>
            </div>
        </div>

        <!-- Szybkie statystyki -->
        <div class="filter-panel p-3">
            <h6 class="text-light mb-3">Szczegóły ocen</h6>
            <div class="stats-row d-flex justify-content-between mb-2">
                <span class="text-secondary">Zgodność z opisem</span>
                <span class="text-light fw-bold">5.0 / 5</span>
            </div>
            <div class="stats-row d-flex justify-content-between mb-2">
                <span class="text-secondary">Czas odpowiedzi</span>
                <span class="text-light fw-bold">4.7 / 5</span>
            </div>
            <div class="stats-row d-flex justify-content-between">
                <span class="text-secondary">Uprzejmość</span>
                <span class="text-light fw-bold">4.9 / 5</span>
            </div>
        </div>
    </div>

    <!-- Prawa kolumna: Lista opinii -->
    <div class="col-lg-8">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="section-title mb-0">Opinie kupujących</h4>
            <select class="form-select form-select-dark w-auto">
                <option>Najnowsze</option>
                <option>Najwyższe oceny</option>
                <option>Najniższe oceny</option>
            </select>
        </div>

        <div style="max-height:300px">
            <!-- Pojedyncza opinia -->
            <div class="listing-card p-4 mb-3">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div class="d-flex align-items-center gap-2">
                        <div class="avatar-sm bg-secondary rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            <span class="text-dark fw-bold">M</span>
                        </div>
                        <div>
                            <h6 class="mb-0 text-light">Marek P.</h6>
                            <small class="text-secondary">2 dni temu</small>
                        </div>
                    </div>
                    <div class="rating-stars text-primary-custom">
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                    </div>
                </div>
                <p class="text-light mt-3">
                    "Świetny kontakt, Macbook w stanie idealnym, dokładnie tak jak w opisie. Bardzo polecam tego sprzedawcę!"
                </p>
                <div class="item-purchased small p-2 rounded bg-dark border border-secondary text-secondary">
                    <i class="bi bi-cart3 me-2"></i>Kupił: MacBook Pro 16" M2 Max
                </div>
            </div>

            <!-- Kolejna opinia -->
            <div class="listing-card p-4 mb-3">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div class="d-flex align-items-center gap-2">
                        <div class="avatar-sm bg-secondary rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            <span class="text-dark fw-bold">A</span>
                        </div>
                        <div>
                            <h6 class="mb-0 text-light">Anna W.</h6>
                            <small class="text-secondary">Tydzień temu</small>
                        </div>
                    </div>
                    <div class="rating-stars text-primary-custom">
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star"></i>
                    </div>
                </div>
                <p class="text-light mt-3">
                    "Wszystko super, szybka wysyłka. Trochę długo czekałam na odpowiedź na czacie, ale ostatecznie transakcja przebiegła pomyślnie."
                </p>
                <div class="item-purchased small p-2 rounded bg-dark border border-secondary text-secondary">
                    <i class="bi bi-cart3 me-2"></i>Kupił: Aparat Sony A7IV Body
                </div>
            </div>
        </div>
    </div>
</div>