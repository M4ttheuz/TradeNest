@model List<TradeNest.Models.Listing>

@{
    ViewData["Title"] = "Obserwowane";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h1 class="section-title mb-2">Obserwowane ogłoszenia</h1>
        <p class="text-secondary-custom mb-0">
            Zapisane oferty w jednym miejscu.
        </p>
    </div>

    <div class="d-flex gap-2">
        <form method="get" asp-controller="Watchlist" asp-action="Index" class="d-inline">
            <input type="hidden" name="phrase" value="@ViewBag.Phrase" />
            <button class="btn btn-secondary-custom rounded-pill">
                <i class="bi bi-funnel me-2"></i>Filtry
            </button>
        </form>

        <a asp-controller="Watchlist" asp-action="Index"
           class="btn btn-primary-custom rounded-pill">
            <i class="bi bi-arrow-repeat me-2"></i>Odśwież
        </a>
    </div>
</div>

<div class="row g-4">

    @if (!Model.Any())
    {
        <div class="col-12">
            <div class="watchlist-empty">
                <i class="bi bi-heart"></i>

                <h3>Brak obserwowanych ogłoszeń</h3>

                <p class="text-secondary-custom">
                    Dodaj pierwsze oferty do obserwowanych.
                </p>
            </div>
        </div>
    }
    else
    {
        @foreach (var listing in Model)
        {
            var mainImage = listing.Images.FirstOrDefault(i => i.IsMain)
            ?? listing.Images.FirstOrDefault();

            var latestPrice = listing.Prices
            .OrderByDescending(p => p.SetAt)
            .FirstOrDefault();

            <div class="col-md-6 col-lg-4">

                <a asp-controller="Listing"
                   asp-action="Details"
                   asp-route-id="@listing.Id"
                   class="text-decoration-none text-reset d-block">
    
                    <div class="listing-card">

                    <div class="listing-img-wrapper">

                        <img src="@(mainImage?.ImagePath ?? "/images/placeholder.jpg")"
                             class="listing-img"
                             alt="@listing.Title">

                        @* <button class="watchlist-btn">
                            <i class="bi bi-heart-fill"></i>
                        </button> *@
                        <form asp-controller="Watchlist"
                              asp-action="Toggle"
                              method="post">

                            <input type="hidden"
                                   name="listingId"
                                   value="@listing.Id" />

                            <button type="submit"
                                    class="watchlist-btn"
                                    onclick="event.stopPropagation();">
                                <i class="bi bi-heart-fill"
                                   style="color:var(--primary-color)">
                                </i>
                            </button>

                        </form>


                    </div>

                    <div class="card-body d-flex flex-column p-3">

                        <h5 class="card-title">
                            @listing.Title
                        </h5>

                        <div class="card-price-row">

                            <p class="card-price">
                                @(latestPrice?.Price.ToString("N0") ?? "0") zł
                            </p>

                        </div>

                        <div class="card-footer-info">

                            <span>
                                <i class="bi bi-geo-alt"></i>
                                @listing.Location
                            </span>

                            <span>
                                @listing.CreatedAt.ToString("dd.MM.yyyy")
                            </span>

                        </div>

                    </div>

                </div>
                </a>

            </div>
        }
    }

</div>